{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Audiophile Ace",
  "version": "0.1.0",
  "identifier": "com.audiophileace.linux",
  "build": {
    "frontendDist": "../../packages/ui/out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "cd ../../packages/ui && pnpm dev",
    "beforeBuildCommand": "cd ../../packages/ui && pnpm build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Audiophile Ace",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false,
        "transparent": true,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": ["libasound2", "libgtk-3-0", "libwebkit2gtk-4.1-0"]
      }
    }
  }
}
